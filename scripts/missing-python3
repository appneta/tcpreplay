#!/bin/sh
# Stand-in for python3 when it is not installed (#895 phase 2).
#
# scripts/autoopts regenerates src/*_opts.c/h and src/*.adoc (the AsciiDoc
# man-page source) from the .def files, replacing GNU autogen for those
# artifacts. They are committed to git and shipped in release tarballs, so
# python3 is only needed to regenerate them after editing a .def file. If
# this script runs, a .def file is newer than its committed generated
# output and regeneration was attempted without python3 installed.

echo "ERROR: python3 is required to regenerate scripts/autoopts output, but is not installed." >&2
echo "       A .def file is newer than its committed generated output." >&2
echo "       Either install python3, or if the .def content is unchanged," >&2
echo "       refresh the timestamps: touch src/*_opts.c src/*_opts.h src/*.adoc" >&2
exit 1
