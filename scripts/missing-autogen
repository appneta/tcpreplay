#!/bin/sh
# Stand-in for GNU autogen when it is not installed (#895).
#
# As of #895 phase 2, autogen is only used to regenerate
# src/tcpedit/tcpedit_stub.h (a distinct AutoOpts "library" template mode
# not yet ported to scripts/autoopts - see scripts/autoopts/README.md).
# Every other AutoOpts-generated file (src/*_opts.c/h, src/*.adoc) is
# produced by scripts/autoopts instead; see scripts/missing-python3.
#
# tcpedit_stub.h is committed to git and shipped in release tarballs, so
# autogen is only needed to regenerate it after editing a .def file it
# depends on. If this script runs, such a .def file is newer than the
# committed tcpedit_stub.h and regeneration was attempted without autogen
# installed.

echo "ERROR: GNU autogen is required to regenerate tcpedit_stub.h, but is not installed." >&2
echo "       A .def file is newer than the committed src/tcpedit/tcpedit_stub.h." >&2
echo "       Either install GNU autogen, or if the .def content is unchanged," >&2
echo "       refresh the timestamp: touch src/tcpedit/tcpedit_stub.h" >&2
exit 1
